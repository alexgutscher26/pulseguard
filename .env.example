# ─── Database ──────────────────────────────────────────────────────────────

# Session pooler connection (runtime for app + worker)
DATABASE_URL="postgresql://user:password@host:5432/db"

# Direct connection (Prisma migrations — db:push, db:migrate)
DIRECT_URL="postgresql://user:password@host:5432/db"

# ─── Auth ──────────────────────────────────────────────────────────────────

# Base URL for the auth server (e.g. http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"

# Cryptographic secret for session cookies (min 32 characters)
BETTER_AUTH_SECRET="replace-with-a-random-string-at-least-32-chars"

# Allowed CORS origin
CORS_ORIGIN="http://localhost:3000"

# ─── Application URLs ──────────────────────────────────────────────────────

# Public-facing app URL (used server- and client-side)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Expo mobile app server URL
EXPO_PUBLIC_SERVER_URL="http://localhost:3000"

# ─── Redis (optional — resilience fallback) ────────────────────────────────

# Upstash Redis REST URL for connection pooling fallback
UPSTASH_REDIS_REST_URL=""

# Upstash Redis authentication token
UPSTASH_REDIS_REST_TOKEN=""

# ─── Email (optional) ──────────────────────────────────────────────────────

# Resend API key for transactional email delivery
RESEND_API_KEY=""

# ─── AI (optional) ─────────────────────────────────────────────────────────

# OpenAI API key for anomaly detection and latency heuristics
OPENAI_API_KEY=""

# ─── Slack Integration (optional) ──────────────────────────────────────────

SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""

# ─── Google OAuth Integration (optional) ───────────────────────────────────

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Cloudflare Worker — Sharding (optional) ───────────────────────────────

# Horizontal scaling: set to 0-based shard index
SHARD_ID=0

# Total number of shards
TOTAL_SHARDS=1

# ─── Infrastructure Deployment (optional) ──────────────────────────────────

# Password for Alchemy-based Cloudflare deployments
ALCHEMY_PASSWORD=""

# ─── Runtime ───────────────────────────────────────────────────────────────

NODE_ENV="development"
