{
  "name": "pulseguard-cli",
  "version": "0.1.0",
  "description": "Official CLI for PulseGuard — Monitoring as Code, live debugging, and CI/CD integration",
  "bin": {
    "pulse": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "echo \"pulseguard-cli ready — run: bunx tsx src/index.ts <command>\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "ora": "^8.1.1",
    "table": "^6.9.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["pulseguard", "monitoring", "cli", "devops", "uptime"],
