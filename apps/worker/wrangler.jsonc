  //     }
  //   ],
  //   "consumers": [
  //     {
  //       "queue": "monitor-checks",
  //       "max_batch_size": 10,
  //       "max_batch_timeout": 5,
  //       "max_retries": 5,
  //       "dead_letter_queue": "monitor-checks-dlq"
  //     },
