{
  "extends": "@pulseguard/config/tsconfig.base.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "baseUrl": ".",
    "paths": {
      "cloudflare:sockets": ["./src/mock-sockets.ts"],
      "cloudflare:workers": ["./src/mock-workers.ts"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.js"],
  "exclude": ["node_modules", "src/**/*.bench.test.ts"]
}
