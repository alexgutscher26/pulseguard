{
  "extends": "@pulseguard/config/tsconfig.base.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noUnusedLocals": false
  },
  "include": ["src/**/*.ts", "scripts/**/*.js"],
  "exclude": ["node_modules", "src/**/*.bench.test.ts"]
}
