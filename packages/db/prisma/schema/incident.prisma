enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum Severity {
  HIGH
  MEDIUM
  LOW
}

enum IncidentEventType {
  STATE_CHANGE
  ALERT_SENT
  COMMENT
  AUTO_RESOLVE
}

model Incident {
  id          String         @id @default(cuid())
  monitorId   String
  monitor     Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status      IncidentStatus @default(INVESTIGATING)
  severity    Severity       @default(HIGH)
  title       String
  description String?
  startedAt   DateTime       @default(now())
  resolvedAt  DateTime?

  // Relations
  events     IncidentEvent[]
  postMortem PostMortem?

  // Audits
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([monitorId])
  @@index([status])
}

model IncidentEvent {
  id         String            @id @default(cuid())
  incidentId String
  incident   Incident          @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       IncidentEventType
  message    String
  createdAt  DateTime          @default(now())

  @@index([incidentId])
}

model RegionalIncident {
  id               String         @id @default(cuid())
  monitorId        String
  monitor          Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  region           String
  status           IncidentStatus @default(INVESTIGATING)
  startedAt        DateTime       @default(now())
  resolvedAt       DateTime?
  avgLatency       Float? // Average latency during incident (ms)
  latencyThreshold Float? // Threshold that was breached (ms)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([monitorId])
  @@index([region])
  @@index([status])
}

model IncidentTemplate {
  id          String         @id @default(cuid())
  name        String
  title       String
  description String
  severity    Severity       @default(HIGH)
  status      IncidentStatus @default(INVESTIGATING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String

  @@index([createdById])
}

enum PostMortemStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model PostMortem {
  id         String   @id @default(cuid())
  incidentId String   @unique
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  summary         String
  rootCause       String
  impactScope     String
  detectionMethod String
  timeline        String   @default("")
  actionItems     String

  status PostMortemStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([incidentId])
}
