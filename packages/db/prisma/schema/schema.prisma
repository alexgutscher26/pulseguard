generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
  output          = "../../src/generated/client"
  engineType      = "wasm"
}

datasource db {
  provider = "postgresql"
}

enum MonitorType {
  HTTP
  PING
  PORT
  BROWSER
  SEQUENCE
  SSL
  DNS
  DOMAIN
  HEARTBEAT
  MCP
  GRAPHQL
  WEBSOCKET
  DATABASE
  BGP
}

enum MonitorStatus {
  UP
  DOWN
  PAUSED
  MAINTENANCE
}

model Monitor {
  id        String        @id @default(cuid())
  name      String
  url       String
  type      MonitorType   @default(HTTP)
  interval  Int           @default(60) // Seconds
  timeout   Int           @default(10) // Seconds
  status    MonitorStatus @default(UP)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  events               MonitorEvent[]
  maintenanceWindows   MaintenanceWindow[]
  alertRules           AlertRule[]
  incidents            Incident[]
  regionalIncidents    RegionalIncident[]
  latencyAggregates    LatencyAggregate[]
  regionalBaselines    RegionalBaseline[]
  statusPages          StatusPageMonitor[]
  monitorSubscriptions MonitorSubscription[]
  dailySummaries       DailyMonitorSummary[]
  insights             MonitorInsight[]
  probeAssignments     ProbeAssignment[]
  heartbeatPings       HeartbeatPing[]
  statusPageOverrides  StatusPageOverride[]

  nextCheck            DateTime?
  lastCheck            DateTime?
  tags                 String[]  @default([])
  checkRegions         String? // JSON array of region codes: ["us-east", "eu-west", "ap-south"]
  alertThreshold       Int       @default(1)
  dynamicThresholding  Boolean   @default(false)
  runbookUrl           String?
  method               String    @default("GET")
  headers              String?   // JSON structure for custom headers
  body                 String?   // Request body for POST/PUT/PATCH
  expectation          String? // JSON structure for response validation
  script               String? // JSON array of declarative steps for BROWSER monitors
  heartbeatToken       String? @unique // Unique token for heartbeat webhook URL

  @@index([userId])
  @@index([nextCheck])
}

enum ProbeStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

model Probe {
  id             String      @id @default(cuid())
  name           String
  token          String      @unique
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         ProbeStatus @default(ACTIVE)
  version        String?
  platform       String?     // "docker", "wasm", "cloudflare-container"
  region         String?     // User-defined label for where this probe runs
  lastHeartbeat  DateTime?
  heartbeatInterval Int     @default(60) // Seconds between expected heartbeats
  ipAddress      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assignments ProbeAssignment[]
  monitorEvents MonitorEvent[]

  @@index([userId])
  @@index([token])
  @@index([status])
}

model ProbeAssignment {
  id        String   @id @default(cuid())
  probeId   String
  probe     Probe    @relation(fields: [probeId], references: [id], onDelete: Cascade)
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([probeId, monitorId])
  @@index([probeId])
  @@index([monitorId])
}

model HeartbeatPing {
  id        String   @id @default(cuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  pingedAt  DateTime @default(now())
  sourceIp  String?
  userAgent String?

  @@index([monitorId, pingedAt(sort: Desc)])
}

model MonitorEvent {
  id          String        @id @default(cuid())
  monitorId   String
  status      MonitorStatus
  latency     Int // Milliseconds
  errorReason String? // "TIMEOUT", "DNS_ERROR", "HTTP_500", etc.
  timestamp   DateTime      @default(now())
  region      String? // Region code where check was performed: "us-east", "eu-west", etc.
  probeId     String? // If checked by a private probe
  probe       Probe?        @relation(fields: [probeId], references: [id], onDelete: SetNull)

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([timestamp])
  @@index([region])
  @@index([probeId])
}

model MaintenanceWindow {
  id        String  @id @default(cuid())
  monitorId String
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  description String?
  startAt     DateTime
  endAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([monitorId])
  @@index([startAt, endAt])
}
