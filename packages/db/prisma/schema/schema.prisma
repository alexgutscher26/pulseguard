generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters", "prismaSchemaFolder"]
  engineType = "wasm"
}

datasource db {
  provider = "postgresql"
}

enum MonitorType {
  HTTP
  PING
  PORT
}

enum MonitorStatus {
  UP
  DOWN
  PAUSED
  MAINTENANCE
}

model Monitor {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      MonitorType @default(HTTP)
  interval  Int      @default(60) // Seconds
  timeout   Int      @default(10) // Seconds
  status    MonitorStatus @default(UP)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  events    MonitorEvent[]
  maintenanceWindows MaintenanceWindow[]

  nextCheck DateTime?
  lastCheck DateTime?

  @@index([userId])
  @@index([nextCheck])
}

model MonitorEvent {
  id        String   @id @default(cuid())
  monitorId String
  status    MonitorStatus
  latency   Int      // Milliseconds
  errorReason String? // "TIMEOUT", "DNS_ERROR", "HTTP_500", etc.
  timestamp DateTime @default(now())
  
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([timestamp])
}

model MaintenanceWindow {
  id          String   @id @default(cuid())
  monitorId   String
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  
  description String?
  startAt     DateTime
  endAt       DateTime
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([monitorId])
  @@index([startAt, endAt])
}
