{
  "name": "pulseguard",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@cloudflare/workers-types": "^4.20251213.0",
      "next": "^16.1.1",
      "@prisma/client": "^7.2.0",
      "@trpc/server": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "@trpc/tanstack-react-query": "^11.7.2",
      "@tanstack/react-query": "^5.90.12",
      "better-auth": "^1.4.9",
      "alchemy": "^0.82.1",
      "@better-auth/expo": "^1.4.9",
      "resend": "^4.0.0",
      "@react-email/components": "^0.0.25",
      "@react-email/render": "^1.0.1"
    }
  },
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-env.js",
    "dev": "turbo dev --filter=!@pulseguard/infra",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:worker": "turbo -F @pulseguard/worker dev",
    "db:push": "turbo -F @pulseguard/db db:push",
    "db:studio": "turbo -F @pulseguard/db db:studio",
    "db:generate": "turbo -F @pulseguard/db db:generate",
    "db:migrate": "turbo -F @pulseguard/db db:migrate",
    "deploy": "turbo -F @pulseguard/infra deploy",
    "destroy": "turbo -F @pulseguard/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@pulseguard/env": "workspace:*",
    "dotenv": "catalog:",
    "next-intl": "^4.8.2",
    "port-nuker": "^1.0.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@pulseguard/config": "workspace:*",
    "@types/node": "^22.13.14",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.34.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.6"
}
